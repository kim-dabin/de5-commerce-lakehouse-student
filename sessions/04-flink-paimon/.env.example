# Data Engineering Bootcamp 5 - Lite Lab Stack

COMPOSE_PROJECT_NAME=de5-lite

# Kafka
KAFKA_IMAGE=apache/kafka:3.9.1
KAFKA_CLUSTER_ID=4L6g3nShT-eMCtK--X86sw
KAFKA_TOPIC=commerce-events
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
KAFKA_UI_HOST_PORT=8088

# Flink
FLINK_IMAGE=de5-flink:1.20.4-paimon
FLINK_BASE_IMAGE=flink:1.20.4-scala_2.12-java17
FLINK_KAFKA_CONNECTOR_VERSION=3.4.0-1.20
PAIMON_VERSION=1.4.1
ICEBERG_FLINK_RUNTIME_VERSION=1.11.0
FLINK_SHADED_HADOOP_VERSION=2.8.3-10.0

# Spark
SPARK_IMAGE=de5-spark:3.5.6-java17
SPARK_BASE_IMAGE=apache/spark:3.5.6-java17
ICEBERG_VERSION=1.11.0

# Realtime OLAP
STARROCKS_FE_IMAGE=starrocks/fe-ubuntu:4.0-latest
STARROCKS_CN_IMAGE=starrocks/cn-ubuntu:4.0-latest
STARROCKS_FE_HTTP_PORT=8030
STARROCKS_CN_HTTP_PORT=8040
STARROCKS_FE_QUERY_PORT=9030
STARROCKS_MINIO_BUCKET=starrocks
STARROCKS_MINIO_ACCESS_KEY=AAAAAAAAAAAAAAAAAAAA
STARROCKS_MINIO_SECRET_KEY=BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB

# Airflow
AIRFLOW_IMAGE=de5-airflow:2.10.5
AIRFLOW_BASE_IMAGE=apache/airflow:2.10.5-python3.11
AIRFLOW_HOST_PORT=8080
AIRFLOW_DB_IMAGE=postgres:15-alpine
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_DB_NAME=airflow
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# Kafka producer
PRODUCER_IMAGE=de5-producer:python3.12
CONFLUENT_KAFKA_VERSION=2.14.0

# Object storage
MINIO_IMAGE=minio/minio:latest
MINIO_CLIENT_IMAGE=minio/mc:latest
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_PAIMON_BUCKET=paimon
MINIO_STARROCKS_BUCKET=starrocks

# Iceberg REST catalog
ICEBERG_REST_IMAGE=tabulario/iceberg-rest:1.6.0
POSTGRES_IMAGE=postgres:15-alpine
POSTGRES_HOST_PORT=15432
ICEBERG_DB_USER=iceberg
ICEBERG_DB_PASSWORD=iceberg
ICEBERG_DB_NAME=iceberg
